POSTGRES_DB=aitaskqueue
POSTGRES_USER=app
POSTGRES_PASSWORD=app_dev_password
POSTGRES_PORT=5432
DATABASE_URL=postgresql://app:app_dev_password@localhost:5432/aitaskqueue

REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

RABBITMQ_USER=app
RABBITMQ_PASSWORD=app_dev_password
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672
RABBITMQ_URL=amqp://app:app_dev_password@localhost:5672
RABBITMQ_PREFETCH_COUNT=5

ORCHESTRATOR_URL=http://localhost:3001
MOCK_PROVIDER=true
SYSTEM_USER_ID=<uuid-of-seeded-system-user>

API_GATEWAY_PORT=3000
TASK_ORCHESTRATOR_PORT=3001
WORKER_OPENAI_PORT=3002
WORKER_ANTHROPIC_PORT=3003
WORKER_REPLICATE_PORT=3004
PROMETHEUS_PORT=9090

RATE_LIMIT_FREE_RPM=10
RATE_LIMIT_FREE_BURST=15
RATE_LIMIT_PRO_RPM=100
RATE_LIMIT_PRO_BURST=150
RATE_LIMIT_ENTERPRISE_RPM=1000
RATE_LIMIT_ENTERPRISE_BURST=1500

CIRCUIT_FAILURE_THRESHOLD=5
CIRCUIT_SUCCESS_THRESHOLD=2
CIRCUIT_OPEN_TIMEOUT_MS=30000

QUEUE_DEPTH_THRESHOLD=500

CACHE_TTL_SECONDS=3600
CACHE_ENABLED=true

BATCH_MAX_SIZE_OPENAI=20
BATCH_TIMEOUT_MS_OPENAI=200
BATCH_MAX_SIZE_ANTHROPIC=10
BATCH_TIMEOUT_MS_ANTHROPIC=300
BATCH_MAX_SIZE_REPLICATE=5
BATCH_TIMEOUT_MS_REPLICATE=500

OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
REPLICATE_API_TOKEN=r8_...

NODE_ENV=development
LOG_LEVEL=debug
